{
  "compilerOptions": {
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "isolatedModules": true,
    "strict": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "md-to-docx/**/*.ts",
    "md-to-pdf/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "**/tests/**"
  ]
}
